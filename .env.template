# EthervoxAI Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to Git

# App environment (development | staging | production)
EXPO_PUBLIC_APP_ENV=development

# EAS project ID (from eas.json after eas init)
EXPO_PUBLIC_EAS_PROJECT_ID=

# Optional: partner sync endpoint (Pro tier only)
EXPO_PUBLIC_SYNC_ENDPOINT=

# SQLite encryption key (auto-generated on first run if empty)
EXPO_PUBLIC_DB_KEY=
